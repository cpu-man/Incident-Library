<Page x:Class="Incident_Library.WPF_VIEWS.SUB_VIEWS.EditIncidentReport"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="White"
      FontFamily="Segoe UI"
      FontSize="13">

    <Page.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="ClassicTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#7A7A7A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="ClassicButton" TargetType="Button">
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#ADADAD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,4"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5F3FF"/>
                                <Setter Property="BorderBrush" Value="#0078D7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CCE4F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- Form -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="20,16,20,0">
            <StackPanel>

                <!-- Title -->
                <TextBlock Text="Title:" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtTitle"
                         Style="{StaticResource ClassicTextBox}"
                         Height="26" Margin="0,0,0,12"/>

                <!-- Status -->
                <TextBlock Text="Status:" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="cmbStatus"
                          Height="26" BorderBrush="#7A7A7A"
                          Margin="0,0,0,12">
                    <ComboBoxItem Content="Work In Progress" IsSelected="True"/>
                    <ComboBoxItem Content="Under Review"/>
                    <ComboBoxItem Content="Awaiting Approval"/>
                    <ComboBoxItem Content="Archived"/>
                </ComboBox>

                <!-- Labels -->
                <TextBlock Text="Labels:" Style="{StaticResource FieldLabel}"/>
                <Border BorderBrush="#7A7A7A" BorderThickness="1"
                        Background="White" Padding="6" Margin="0,0,0,12" MinHeight="34">
                    <WrapPanel x:Name="labelsPanel">
                        <Button Content="+ Add Label"
                                Style="{StaticResource ClassicButton}"
                                Padding="8,2" Height="22" FontSize="11"
                                Click="BtnAddLabel_Click"/>
                    </WrapPanel>
                </Border>

                <!-- What is the incident? -->
                <TextBlock Text="What is the incident?" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtWhatIsIncident"
                         Style="{StaticResource ClassicTextBox}"
                         Height="70" TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,12"/>

                <!-- How was it discovered? -->
                <TextBlock Text="How did you discover the incident?" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtHowDiscovered"
                         Style="{StaticResource ClassicTextBox}"
                         Height="70" TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,12"/>

                <!-- How was it resolved? -->
                <TextBlock Text="How did you resolve the incident?" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtHowResolved"
                         Style="{StaticResource ClassicTextBox}"
                         Height="70" TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,16"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Save / Cancel bar -->
        <Border Grid.Row="1" Background="#F0F0F0"
                BorderBrush="#ADADAD" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="16,0">
                <TextBlock x:Name="txtValidationError"
                           Foreground="Red" FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Visibility="Collapsed"/>
                <Button Content="Delete"
                        Style="{StaticResource ClassicButton}"
                        Click="BtnDelete_Click"
                        Margin="0,0,8,0"/>
                <Button Content="Save"
                        Style="{StaticResource ClassicButton}"
                        Click="BtnSave_Click"
                        Margin="0,0,8,0"/>
                <Button Content="Cancel"
                        Style="{StaticResource ClassicButton}"
                        Click="BtnCancel_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
