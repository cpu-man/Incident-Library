<Page x:Class="Incident_Library.WPF_VIEWS.SUB_VIEWS.AwaitingApproval"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="White"
      FontFamily="Segoe UI"
      FontSize="13">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F0F0F0"
                BorderBrush="#ADADAD" BorderThickness="0,0,0,1">
            <Grid Margin="12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Title"          FontWeight="SemiBold" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="What is it?"    FontWeight="SemiBold" FontSize="12"/>
                <TextBlock Grid.Column="2" Text="How Discovered" FontWeight="SemiBold" FontSize="12"/>
                <TextBlock Grid.Column="3" Text="Action"         FontWeight="SemiBold" FontSize="12"/>
            </Grid>
        </Border>

        <ListBox x:Name="IncidentList"
                 Grid.Row="1"
                 BorderThickness="0"
                 Background="White"
                 SelectionChanged="IncidentList_SelectionChanged">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#CCE4F7"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F0F0F0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#DFDFDF" BorderThickness="0,0,0,1"
                            Padding="12,10" Cursor="Hand">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding Title}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="1" Text="{Binding WhatIsIncident}"
                                       FontSize="12" Foreground="#555"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="2" Text="{Binding HowDiscovered}"
                                       FontSize="12" Foreground="#555"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="✓"
                                        Tag="{Binding Id}"
                                        Click="BtnApprove_Click"
                                        Width="28" Height="22"
                                        FontSize="12"
                                        Background="#E1E1E1"
                                        BorderBrush="#ADADAD"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Margin="0,0,4,0"
                                        ToolTip="Approve"/>
                                <Button Content="✕"
                                        Tag="{Binding Id}"
                                        Click="BtnReject_Click"
                                        Width="28" Height="22"
                                        FontSize="12"
                                        Background="#E1E1E1"
                                        BorderBrush="#ADADAD"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        ToolTip="Reject"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Grid.Row="1" x:Name="txtEmpty"
                   Text="No incidents awaiting approval."
                   Foreground="#888" FontSize="13"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed"/>
    </Grid>
</Page>