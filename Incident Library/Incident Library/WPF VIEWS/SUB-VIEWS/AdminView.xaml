<Page x:Class="Incident_Library.WPF_VIEWS.SUB_VIEWS.AdminView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="White"
      FontFamily="Segoe UI"
      FontSize="13">

    <Page.Resources>
        <Style x:Key="ClassicButton" TargetType="Button">
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#ADADAD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,3"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5F3FF"/>
                                <Setter Property="BorderBrush" Value="#0078D7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CCE4F7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#ADADAD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Section: Users -->
            <RowDefinition Height="Auto"/>
            <!-- User toolbar -->
            <RowDefinition Height="*"/>
            <!-- User list -->
        </Grid.RowDefinitions>

        <!-- Section header -->
        <Border Grid.Row="0" Background="#F0F0F0"
                BorderBrush="#ADADAD" BorderThickness="0,0,0,1"
                Padding="12,8">
            <TextBlock Text="User Management" FontSize="13" FontWeight="SemiBold"/>
        </Border>

        <!-- User toolbar -->
        <Border Grid.Row="1" Background="#F5F5F5"
                BorderBrush="#ADADAD" BorderThickness="0,0,0,1"
                Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <Button Content="+ Add User"
                        Style="{StaticResource ClassicButton}"
                        Click="BtnAddUser_Click"
                        Margin="0,0,4,0"/>
                <Button x:Name="btnRemoveUser"
                        Content="Remove User"
                        Style="{StaticResource ClassicButton}"
                        Click="BtnRemoveUser_Click"
                        IsEnabled="False"
                        Margin="0,0,4,0"/>
                <Button x:Name="btnChangeRole"
                        Content="Change Role"
                        Style="{StaticResource ClassicButton}"
                        Click="BtnChangeRole_Click"
                        IsEnabled="False"/>
            </StackPanel>
        </Border>

        <!-- User list -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Column headers -->
            <Border Grid.Row="0" Background="#F0F0F0"
                    BorderBrush="#ADADAD" BorderThickness="0,0,0,1">
                <Grid Margin="12,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ID"   FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="Name" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Grid.Column="2" Text="Role" FontWeight="SemiBold" FontSize="12"/>
                </Grid>
            </Border>

            <!-- Users -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="UserList"
                         BorderThickness="0"
                         Background="White"
                         SelectionChanged="UserList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#CCE4F7"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F0F0F0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DFDFDF" BorderThickness="0,0,0,1" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding PersonID}"
                                               FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Border Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding RoleName}"
                                                   FontSize="12" Foreground="#555"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

            <TextBlock Grid.Row="1" x:Name="txtEmpty"
                       Text="No users found."
                       Foreground="#888" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed"/>
            
            <!-- Section header: Incidents -->
            <Border Grid.Row="3" Background="#F0F0F0"
        BorderBrush="#ADADAD" BorderThickness="0,0,0,1"
        Padding="12,8">
                <TextBlock Text="Incident Management" FontSize="13" FontWeight="SemiBold"/>
            </Border>

            <!-- Incident list -->
            <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="IncidentList" BorderThickness="0" Background="White">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DFDFDF" BorderThickness="0,0,0,1" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Id}"
                                   FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Status}"
                                   FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
                                    <Button Grid.Column="3" Content="Edit"
                                Tag="{Binding}"
                                Click="BtnEditIncident_Click"
                                Style="{StaticResource ClassicButton}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

        </Grid>
    </Grid>
</Page>
